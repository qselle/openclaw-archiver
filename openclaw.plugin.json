{
  "id": "archiver",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "port": {
        "type": "number",
        "default": 8787,
        "description": "HTTP server port for serving archived pages"
      },
      "storagePath": {
        "type": "string",
        "description": "Override storage directory (default: ~/.web-archiver/pages)"
      },
      "baseUrl": {
        "type": "string",
        "description": "Public base URL for archive links (e.g. https://clawd.galago-chromatic.ts.net/archive)"
      },
      "browser": {
        "type": "object",
        "properties": {
          "headless": { "type": "boolean", "default": true },
          "timeout": { "type": "number", "default": 30000, "description": "Page load timeout in ms" },
          "userDataDir": { "type": "string", "description": "Persistent browser profile directory" },
          "proxy": { "type": "string", "description": "Proxy server URL (e.g. socks5://100.x.x.x:1080)" }
        }
      }
    }
  }
}
